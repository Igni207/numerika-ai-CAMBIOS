  %%  FLUJOS PRINCIPALES
  %% ═══════════════════════════════════════════════════════════════════

  %% --- Flujo A: Resolver un método numérico ---
  %% Usuario → SolverPage → numericalMethods.js → Resultado
  %%        → convergenceAnalyzer.js → Análisis
  %%        → InteractiveChart → Gráfico
  %%        → /api/ai/explain → Explicación pedagógica

  %% --- Flujo B: Chat con IKA ---
  %% Usuario → IkaWidget → IkaContext (espía página actual)
  %%        → POST /api/ai/chat (message + context + history)
  %%        → OpenAI → Respuesta con Markdown/KaTeX

  %% --- Flujo C: Autenticación ---
  %% Usuario → LoginPage/RegisterPage → POST /api/auth/*
  %%        → bcrypt + JWT → AuthContext (token localStorage)
  %%        → GET /api/auth/me (validación al cargar app)

  %% --- Flujo D: Simuladores AMN ---
  %% Usuario → /aplicaciones → Amn.jsx (lista AMN_CARDS)
  %%        → /aplicaciones/:appId → APLICATION_MAP[appId]
  %%        → Componente simulador → numericalMethods.js / SystemEcuation.js

